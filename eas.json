{
  "cli": {
    "version": ">= 7.8.2"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "@GOOGLE_WEB_CLIENT_ID_DEV",
        "EXPO_PUBLIC_POSTHOG_KEY": "@POSTHOG_KEY_DEV",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "@GOOGLE_WEB_CLIENT_ID_DEV",
        "EXPO_PUBLIC_POSTHOG_KEY": "@POSTHOG_KEY_DEV",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      }
    },
    "production": {
      "android": {
        "autoIncrement": true,
        "buildType": "app-bundle"
      },
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "@GOOGLE_WEB_CLIENT_ID_DEV",
        "EXPO_PUBLIC_POSTHOG_KEY": "@POSTHOG_KEY_DEV",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
